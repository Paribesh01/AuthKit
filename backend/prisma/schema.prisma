generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Developer (signs into our dashboard) ───────────────────────────────────

model Developer {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String?
  lastName      String?
  passwordHash  String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions             DeveloperSession[]
  emailVerifications   DeveloperEmailVerification[]
  passwordResets       DeveloperPasswordReset[]
  applications         Application[]

  @@map("developers")
}

model DeveloperSession {
  id           String   @id @default(cuid())
  developerId  String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@map("developer_sessions")
}

model DeveloperEmailVerification {
  id          String   @id @default(cuid())
  developerId String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@map("developer_email_verifications")
}

model DeveloperPasswordReset {
  id          String   @id @default(cuid())
  developerId String
  token       String   @unique
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@map("developer_password_resets")
}

// ─── Application (created by a developer) ───────────────────────────────────

model Application {
  id              String   @id @default(cuid())
  developerId     String
  name            String
  publishableKey  String   @unique
  secretKey       String   @unique
  allowedOrigins  String[] @default([])
  webhookUrl      String?
  webhookSecret   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  developer      Developer       @relation(fields: [developerId], references: [id], onDelete: Cascade)
  users          AppUser[]
  oauthProviders OAuthProvider[]
  events         AppEvent[]
  settings       AppSettings?

  @@map("applications")
}

model AppEvent {
  id            String   @id @default(cuid())
  applicationId String
  eventType     String
  actorId       String?
  actorEmail    String?
  ipAddress     String?
  userAgent     String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt(sort: Desc)])
  @@map("app_events")
}

// ─── Application settings (one row per app) ─────────────────────────────────

model AppSettings {
  id                     String  @id @default(cuid())
  applicationId          String  @unique
  passwordMinLength      Int     @default(8)
  requireUppercase       Boolean @default(false)
  requireNumber          Boolean @default(false)
  requireEmailVerification Boolean @default(false)
  allowSignups           Boolean @default(true)
  sessionDurationHours   Int     @default(168) // 7 days
  maxSessionsPerUser     Int     @default(5)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("app_settings")
}

// ─── AppUser (an end-user inside a developer's application) ─────────────────

model AppUser {
  id              String   @id @default(cuid())
  applicationId   String
  externalId      String?
  email           String?
  username        String?
  firstName       String?
  lastName        String?
  imageUrl        String?
  passwordHash    String?
  emailVerified   Boolean  @default(false)
  banned          Boolean  @default(false)
  publicMetadata  Json?
  privateMetadata Json?
  lastSignInAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application        Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  sessions           AppSession[]
  emailVerifications AppEmailVerification[]
  passwordResets     AppPasswordReset[]
  oauthAccounts      OAuthAccount[]
  mfa                AppUserMfa?
  emailOtps          AppEmailOtp[]

  @@unique([applicationId, email])
  @@unique([applicationId, username])
  @@map("app_users")
}

model AppSession {
  id           String   @id @default(cuid())
  appUserId    String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@map("app_sessions")
}

model AppEmailVerification {
  id        String   @id @default(cuid())
  appUserId String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@map("app_email_verifications")
}

model AppPasswordReset {
  id        String   @id @default(cuid())
  appUserId String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@map("app_password_resets")
}

// ─── OAuth ───────────────────────────────────────────────────────────────────

model OAuthProvider {
  id            String   @id @default(cuid())
  applicationId String
  provider      String   // "google" | "github"
  clientId      String?
  clientSecret  String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, provider])
  @@map("oauth_providers")
}

model AppUserMfa {
  id         String   @id @default(cuid())
  appUserId  String   @unique
  secret     String   // base32 TOTP secret (store encrypted in prod)
  enabled    Boolean  @default(false)
  backupCodes String[] // hashed backup codes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@map("app_user_mfa")
}

model AppEmailOtp {
  id        String   @id @default(cuid())
  appUserId String
  code      String   // 6-digit hashed OTP
  purpose   String   // "email_verify" | "signin"
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@index([appUserId, purpose])
  @@map("app_email_otps")
}

model OAuthAccount {
  id         String   @id @default(cuid())
  appUserId  String
  provider   String   // "google" | "github"
  providerId String   // provider's user ID
  email      String?
  createdAt  DateTime @default(now())

  appUser AppUser @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  @@unique([appUserId, provider])
  @@unique([provider, providerId])
  @@map("oauth_accounts")
}
